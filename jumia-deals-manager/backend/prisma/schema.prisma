// =============================================================================
// Prisma Schema — Jumia Vendor Campaign Management Platform
// Database: PostgreSQL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMIN
  VENDOR
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

enum ItemStatus {
  PENDING
  APPROVED
  REJECTED
}

// =============================================================================
// USERS
// Represents both Admin and Vendor-role users who log in to the platform.
// =============================================================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VENDOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // A vendor-role user belongs to exactly one Vendor company
  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  // An admin user can be the account manager for multiple vendors
  managedVendors Vendor[] @relation("AccountManager")

  // Submissions this user personally submitted
  submissions Submission[]

  @@index([email])
  @@index([vendorId])
  @@map("users")
}

// =============================================================================
// VENDORS
// Represents a vendor company. Multiple users can belong to one vendor.
// =============================================================================

model Vendor {
  id             String       @id @default(uuid())
  companyName    String
  contactEmail   String
  contactPhone   String?
  status         VendorStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // The admin user who manages this vendor's account
  accountManagerId String?
  accountManager   User?   @relation("AccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)

  // Users (vendor employees) belonging to this company
  users User[]

  // Products this vendor owns in the catalog
  products Product[]

  // All submissions made by this vendor
  submissions Submission[]

  @@index([companyName])
  @@map("vendors")
}

// =============================================================================
// PRODUCTS (Master SKU Catalog)
// Each product/SKU is owned by one vendor.
// =============================================================================

model Product {
  sku            String  @id  // e.g. "JUM-12345"
  name           String
  category       String
  brand          String
  livePrice      Decimal @db.Decimal(12, 2)
  bestPrice      Decimal @db.Decimal(12, 2)  // Best (lowest) historical price
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // The vendor who owns this SKU in the catalog
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // SubmissionItems that reference this product
  submissionItems SubmissionItem[]

  @@index([vendorId])
  @@index([category])
  @@index([brand])
  @@map("products")
}

// =============================================================================
// CAMPAIGNS
// A promotional event. Vendors submit SKUs to participate.
// =============================================================================

model Campaign {
  id          String         @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      CampaignStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Filters: JSON arrays of eligible categories and brands.
  // NULL = no restriction (all eligible).
  // e.g. ["Electronics", "Mobile"] or ["Samsung", "Apple"]
  eligibleCategories String[] // PostgreSQL text[]
  eligibleBrands     String[] // PostgreSQL text[]

  // All submissions made for this campaign
  submissions Submission[]

  @@index([status])
  @@index([startDate, endDate])
  @@map("campaigns")
}

// =============================================================================
// SUBMISSIONS (Deal Proposals)
// A vendor submits a batch of SKUs for a specific campaign.
// One vendor may have at most one submission per campaign (enforced via unique index).
// =============================================================================

model Submission {
  id          String           @id @default(uuid())
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  notes       String?          // Optional admin note on bulk approve/reject

  // Parent campaign
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  // Owning vendor company
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // The individual user who submitted (could be any vendor user in the company)
  submittedById String
  submittedBy   User   @relation(fields: [submittedById], references: [id], onDelete: Restrict)

  // Line items (individual SKUs in this submission)
  items SubmissionItem[]

  // A vendor can only have one active submission per campaign
  @@unique([campaignId, vendorId])

  @@index([status])
  @@index([campaignId])
  @@index([vendorId])
  @@map("submissions")
}

// =============================================================================
// SUBMISSION ITEMS
// Each row is one SKU inside a submission, with its proposed promo terms.
// The parent Submission's status is DERIVED from these item statuses.
// =============================================================================

model SubmissionItem {
  id           String     @id @default(uuid())
  promoPrice   Decimal    @db.Decimal(12, 2)
  promoStock   Int
  status       ItemStatus @default(PENDING)
  // Computed at write time for fast reporting; re-computed on price change.
  discountPct  Decimal?   @db.Decimal(5, 2) // e.g. 15.50 = 15.5%
  adminNote    String?    // Per-SKU admin rejection reason
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Parent submission
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // The product being proposed
  productSku String
  product    Product @relation(fields: [productSku], references: [sku], onDelete: Restrict)

  // A SKU can only appear once per submission
  @@unique([submissionId, productSku])

  @@index([submissionId])
  @@index([productSku])
  @@index([status])
  @@map("submission_items")
}
